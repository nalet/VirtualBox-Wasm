# Don't export non-ose images.
/images/NonOSE*: --svn-sync-process-export none

# The accessibility info is also private.
/accessibility*: --svn-sync-process-export none

# The .qrc files are (mostly?) autogenerated and have no copyright or license in them.
/*.qrc: --no-update-license --no-update-copyright-year

/src/*.h: --guard-relative-to-dir src/ --guard-prefix FEQT_INCLUDED_SRC_
/src/precomp.h:     --no-fix-header-guards
/src/precomp_vcc.h: --no-fix-header-guards
/src/precomp_gcc.h: --no-fix-header-guards
/src/platform/darwin/*PkgInfo: --treat-as plaintext
/src/platform/win/VirtualBox.VisualElementsManifest.xml: --external-copyright

/precomptricks/*:   --no-fix-header-guards --no-update-license --no-update-copyright-year --treat-as .h

