{
    Cfgm:
    {
        Name:      'Test',
        NumCPUs:   1,
        HMEnabled: true,
        EnablePAE: true,
        RamSize:   4294967296,
        CPUM: { Enable64bit: true, GuestCpuName: 'host' },
        HM: { 64bitEnabled: true, EnableNestedPaging: true, EnableUX: true },
        Devices:
        {
            "apic/0":
            {
                Trusted: true,
                Config:
                {
                    IOAPIC:  true,
                    Mode:    3,
                    NumCPUs: 1
                }
            },
            "acpi/0":
            {
                PCIBusNo: 0,
                PCIDeviceNo: 7,
                PCIFunctionNo: 0,
                Trusted:           true,
                Config:
                {
                    IOAPIC:        true,
                    IocPciAddress: 65536,
                    NumCPUs:       1,
                    ShowCpu:       true,
                    PciPref64Enabled: true,
                    ShowRtc:          true,
                    McfgBase: 0, McfgLength: 0,
                    HostBusPciAddress: 0,
                    FdcEnabled: false
                },
                "LUN#0": { Driver: 'ACPIHost' }
            },
            "ioapic/0":
            {
                Config: { NumCPUs: 1 }
            },
            "pci/0":
            {
                Trusted: true,
                Config: { IOAPIC: true }
            },
            "efi/0":
            {
                Trusted: true,
                Config: { 64BitEntry: true, APIC: true, IOAPIC: true, NumCPUs: 1,
                          McfgBase: 0, McfgLength: 0,
                          EfiRom: "/mnt/VirtualBox/vbox-bisect/out/linux.amd64/debug/bin/VBoxEFI-amd64.fd", UUID: "bytes:AAAAAAAAAAAAAAAAAAAAAA==",
                          DeviceProps: "" }
            },
            "pckbd/0":
            {
                Trusted: 1,
                Config: { },
                "LUN#0":
                {
                    Driver: 'KeyboardQueue',
                    AttachedDriver: { Driver: "MainKeyboard" }
                }
            },
            "mc146818/0/Config": { UseUTC: true },
            "i8259/0":
            {
                Trusted: 1,
                Config: { }
            },
            "i8254/0/Config": { },
            "pcarch/0":
            {
                Trusted: 1,
                Config: { }
            },
            "8237A/0":
            {
                Trusted: 1,
                Config: { }
            },
            "vga/0":
            {
                PCIBusNo: 0,
                PCIDeviceNo: 2,
                PCIFunctionNo: 0,
                Trusted: true,
                Config:
                {
                    FadeIn:             false,
                    FadeOut:            false,
                    VMSVGAEnabled:      false,
                    VMSVGAPciBarLayout: false,
                    VMSVGAPciId:        false,
                    VRamSize:           134217728,
                    VmSvgaExposeLegacyVga: true
                },
                "LUN#0": { Driver: "MainDisplay" }
            },
/*
            "qemu-fw-cfg/0":
            {
                Trusted: true,
                Config:
                {
                    QemuRamfbSupport: true,
                    DmaEnabled:       true
                }
            },
*/
            "ahci/0":
            {
                PCIBusNo: 0,
                PCIDeviceNo: 13,
                PCIFunctionNo: 0,
                Trusted: true,
                Config: { Bootable: true, PortCount: 2 },
                "LUN#1":
                {
                    Driver: "SCSI",
                    AttachedDriver:
                    {
                        Driver: "VD",
                        Config:
                        {
                            ReadOnly: true,
                            UseNewIo: true,
                            Mountable: true,
                            Type: "DVD",
                            Path: "/mnt/Images/Isos/Linux/Ubuntu/ubuntu-25.10-desktop-amd64.iso",
                            Format: "RAW"
                        }
                    }
                }
            }
        }
    }
}
